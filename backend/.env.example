# Server
NODE_ENV=development
PORT=8035

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eventcarbon
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (generate secure secrets in production)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8035/api/auth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8035/api/auth/github/callback

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Bcrypt
BCRYPT_ROUNDS=12

# Paystack Payment Gateway
PAYSTACK_SECRET_KEY=sk_test_42b29036af75c2b624f02ec627a83e968c6bdb92
PAYSTACK_PUBLIC_KEY=pk_test_dba285fe8f4ce325811b3aebc281aec17d3867a6
PAYSTACK_CALLBACK_URL=https://ecobserve.com/api/payments/callback
PAYSTACK_WEBHOOK_URL=https://ecobserve.com/api/payments/webhook

# OpenAI API (for AI-powered features - Impact Leader tier)
OPENAI_API_KEY=sk-placeholder-get-from-openai-platform
OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.7

# OpenWeather API (for climate impact analysis - Impact Leader tier)
OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_API_ENDPOINT=https://api.openweathermap.org/data/2.5

# Email Service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@ecobserve.com

