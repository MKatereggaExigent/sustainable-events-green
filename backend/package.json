{
  "name": "ecobserve-backend",
  "version": "1.0.0",
  "description": "EcobServe Backend API with Multi-tenancy, RBAC, OAuth 2.0, JWT",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node dist/migrations/run.js",
    "migrate:dev": "ts-node src/migrations/run.ts",
    "migrate:create": "./scripts/create-migration.sh",
    "migrate:check": "./scripts/check-migrations.sh",
    "migrate:deploy": "./scripts/deploy-migration.sh",
    "seed": "node dist/migrations/seed.js",
    "seed:dev": "ts-node src/migrations/seed.ts",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.3",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "paystack": "^2.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "speakeasy": "^2.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.5.5",
    "@types/passport": "^1.0.16",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^9.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
